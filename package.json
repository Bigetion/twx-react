{
  "name": "twx-react",
  "version": "0.1.1",
  "description": "Pure React styling library - Component-first Tailwind CSS runtime engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "rollup -c rollup.config.js --watch",
    "build": "rollup -c rollup.config.js",
    "test": "jest",
    "test:compat": "jest tests/internal/compatibility-corpus.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint:fix": "eslint src/**/*.{ts,tsx} --fix",
    "size": "size-limit",
    "size:analyze": "size-limit --why",
    "prepublishOnly": "npm run type-check && npm run test && npm run build"
  },
  "keywords": [
    "react",
    "tailwind",
    "tailwindcss",
    "css",
    "css-in-js",
    "styling",
    "components",
    "variants",
    "runtime",
    "zero-build",
    "typescript"
  ],
  "author": "Bigetion",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bigetion/twx-react.git"
  },
  "homepage": "https://github.com/Bigetion/twx-react",
  "bugs": {
    "url": "https://github.com/Bigetion/twx-react/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "11.0.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.45",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup": "^4.9.1",
    "rollup-plugin-dts": "^6.1.0",
    "size-limit": "11.0.0",
    "ts-jest": "^29.4.11",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "sideEffects": true,
  "size-limit": [
    {
      "path": "dist/index.esm.js",
      "limit": "20 KB"
    },
    {
      "path": "dist/index.min.js",
      "limit": "16 KB"
    }
  ]
}
